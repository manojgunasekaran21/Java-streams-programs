====String Frequency====
import java.util.*;
import java.util.function.Function;
import java.util.stream.Collectors;

class Main {
    public static void main(String[] args) {
        System.out.println("Hello World in Java"); 
        String str = "banana";
        Map<Character, Long> charFreq = str.chars()
                            .mapToObj(c -> (char) c)
                            .collect(Collectors.groupingBy(
                                Function.identity(),
                                Collectors.counting()
                            ));
        System.out.println(charFreq);
    }
}


=====Word frequency====
import java.util.*;
import java.util.function.Function;
import java.util.stream.Collectors;

class Main {
    public static void main(String[] args) {
        String sentence = "java stream java api";
        Map<String, Long> wordFreq = Arrays.stream(sentence.split(" ")).
        collect(Collectors.groupingBy(
            Function.identity(),
            Collectors.counting()
        ));    
        System.out.println(wordFreq);
    }
}


====Average of array numbers===
import java.util.*;
import java.util.function.Function;
import java.util.stream.Collectors;

class Main {
    public static void main(String[] args) {
       List<Integer> nums = Arrays.asList(10, 20, 30, 40);
       double avg = nums.stream()
                    .mapToInt(Integer::intValue)
                    .average()
                    .orElse(0);
        System.out.println(avg);
    }
}
